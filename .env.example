# Ne jamais committer de clés réelles. Copiez vers .env.local pour le développement.

# Google Analytics 4 (identifiant de mesure)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Microsoft Clarity (production uniquement)
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Google AdSense
NEXT_PUBLIC_ADSENSE_ID=
NEXT_PUBLIC_AD_SLOT_UNDER_H1=
NEXT_PUBLIC_AD_SLOT_AFTER_RESULT=
NEXT_PUBLIC_AD_SLOT_BEFORE_FOOTER=

# IndexNow (serveur / CI uniquement — jamais de préfixe NEXT_PUBLIC_)
# Doit correspondre au fichier public/<clé>.txt
INDEXNOW_KEY=
# Optionnel : origine canonique (défaut https://brut-vers-net.fr)
# SITE_URL=https://brut-vers-net.fr

# Resend (serveur uniquement — jamais de préfixe NEXT_PUBLIC_)
RESEND_API_KEY=

# Destinataire des messages du formulaire
CONTACT_EMAIL=contact@brut-vers-net.fr

# Expéditeur (domaine vérifié dans Resend)
# Préférer contact@… ou noreply@… selon la config DNS Resend
CONTACT_FROM_EMAIL=Formulaire Brut vers Net <contact@brut-vers-net.fr>
